# ============================================================
# Variables de entorno para producción en VPS
# ============================================================
# Copiar este archivo a .env y completar los valores
# ============================================================

# ---- Base de datos ----
POSTGRES_PASSWORD=tu-password-seguro-aqui

# ---- Seguridad ----
SECRET_KEY=genera-esto-con-python -c "import secrets; print(secrets.token_urlsafe(32))"

# ---- Clerk (Auth) ----
CLERK_SECRET_KEY=sk_live_tu_clerk_secret_key

# ---- Stripe (Billing) ----
STRIPE_SECRET_KEY=sk_live_tu_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_tu_stripe_webhook_secret

# ---- LLM (Ragnar) ----
OPENROUTER_API_KEY=sk-or-v1-tu_openrouter_api_key

# ---- WhatsApp ----
WHATSAPP_PHONE_NUMBER_ID=tu_phone_number_id
WHATSAPP_ACCESS_TOKEN=tu_whatsapp_access_token

# ---- Telegram Bot ----
TELEGRAM_BOT_TOKEN=tu_telegram_bot_token

# ---- Discord Bot ----
DISCORD_BOT_TOKEN=tu_discord_bot_token
DISCORD_CHANNEL_ID=tu_discord_channel_id

# ---- Vapi (Voz) ----
VAPI_API_KEY=tu_vapi_api_key

# ============================================================
# Deployment (VPS) - Nunca hardcodear estas variables
# ============================================================
# Configurar estas variables de entorno en tu máquina local
# o en el sistema CI/CD antes de ejecutar scripts de deploy

# VPS_HOST=100.86.8.81          # IP o dominio del VPS
# VPS_USER=deploy               # Usuario SSH
# VPS_SSH_KEY=/path/to/id_rsa   # Ruta al archivo de clave SSH privada
# VPS_SSH_PASS=your_ssh_password # Password SSH (alternativa a VPS_SSH_KEY)
# REPO_URL=https://github.com/Jemadiar1/ai-platform.git
