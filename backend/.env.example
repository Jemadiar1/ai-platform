# Variables de entorno para desarrollo
# Copiar a .env y ajustar valores

# === Base de datos ===
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/ai_platform

# === Redis ===
REDIS_URL=redis://localhost:6379/0

# === Seguridad ===
SECRET_KEY=change-me-in-production
JWT_EXPIRATION_HOURS=24
JWT_ALGORITHM=HS256

# === LLM ===
NAN_API_KEY=
NAN_API_URL=https://api.nan.builders/v1
LLM_PROVIDER=nan
PRIMARY_MODEL=qwen3.6
FAST_MODEL=qwen3.6
FALLBACK_MODEL=qwen/qwen-2.5-72b-instruct

# === WhatsApp API ===
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# === Telegram API ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=
TELEGRAM_WEBHOOK_SECRET=

# === Discord API ===
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=
DISCORD_PUBLIC_KEY=

# === Logging ===
LOG_LEVEL=INFO

# === Entorno ===
ENVIRONMENT=development