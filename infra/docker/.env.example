# ============================================================
# Variables de entorno para producción en VPS
# ============================================================
# Copiar este archivo a .env y completar los valores
# ============================================================

# ---- Base de datos ----
POSTGRES_PASSWORD=tu-password-seguro-aqui

# ---- Seguridad ----
SECRET_KEY=genera-esto-con-python -c "import secrets; print(secrets.token_urlsafe(32))"

# ---- LLM (Odin) ----
NAN_API_KEY=sk_nan_tu_nan_api_key
NAN_API_URL=https://api.nan.builders/v1
LLM_PROVIDER=nan
PRIMARY_MODEL=qwen3.6
FAST_MODEL=qwen3.6
FALLBACK_MODEL=qwen/qwen-2.5-72b-instruct

# ---- WhatsApp ----
WHATSAPP_PHONE_NUMBER_ID=tu_phone_number_id
WHATSAPP_ACCESS_TOKEN=tu_whatsapp_access_token
WHATSAPP_WEBHOOK_VERIFY_TOKEN=tu_webhook_verify_token

# ---- Telegram ----
TELEGRAM_BOT_TOKEN=tu_telegram_bot_token
TELEGRAM_WEBHOOK_URL=https://tu-dominio.com/api/v1/webhooks/telegram
TELEGRAM_WEBHOOK_SECRET=$(openssl rand -hex 32)

# ---- Discord ----
DISCORD_BOT_TOKEN=tu_discord_bot_token
DISCORD_CHANNEL_ID=tu_discord_channel_id

# ---- CORS ----
CORS_ORIGINS=https://dashboard.tu-dominio.com

# ---- Nginx / SSL ---
NGINX_SERVER_NAME=vmi3151337.contaboserver.net
NGINX_SSL_CERT_PATH=/etc/letsencrypt/live/vmi3151337.contaboserver.net/fullchain.pem
NGINX_SSL_KEY_PATH=/etc/letsencrypt/live/vmi3151337.contaboserver.net/privkey.pem
